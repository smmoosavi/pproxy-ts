{
  "name": "pproxy-ts",
  "version": "1.0.5",
  "packageManager": "pnpm@10.14.0",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "prepare": "husky",
    "pre-commit": "tsc && lint-staged",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,yml,css,scss,md}'",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,yml,css,scss,md}'",
    "test": "bun test",
    "build": "bun run build.ts",
    "start": "node --import tsx src/index.ts",
    "dev": "node --import tsx --watch src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "proxy-chain": "^2.7.1",
    "zod": "^4.4.3"
  }
}
